# Judge0 — code execution backend
# Opsi 1: Public instance (gratis, tanpa API key, ada rate limit)
JUDGE0_API_URL=https://ce.judge0.com
# JUDGE0_API_KEY=  # tidak perlu untuk public instance

# Opsi 2: RapidAPI (lebih stabil, butuh API key)
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your_rapidapi_key_here

# Opsi 3: Self-hosted Judge0
# JUDGE0_API_URL=https://your-judge0-instance.com
# JUDGE0_API_KEY=your_auth_token_here  # opsional tergantung konfigurasi

PUBLIC_SITE_URL=https://belajar-cpp.varnimyr.my.id
