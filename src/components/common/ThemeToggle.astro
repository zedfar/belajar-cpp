---
// No props needed — works entirely client-side
---
<button
  id="theme-toggle"
  class="relative w-9 h-9 rounded-full flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-amber-500 dark:hover:text-amber-400 hover:bg-slate-100 dark:hover:bg-slate-800 active:scale-90 transition-all duration-200"
  aria-label="Toggle dark mode"
>
  <!-- Sun icon (shown in dark mode → click to go light) -->
  <svg
    class="theme-icon sun-icon hidden dark:block"
    xmlns="http://www.w3.org/2000/svg"
    width="20" height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <!-- Moon icon (shown in light mode → click to go dark) -->
  <svg
    class="theme-icon moon-icon block dark:hidden"
    xmlns="http://www.w3.org/2000/svg"
    width="20" height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<style>
  .theme-icon {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease;
  }
  .theme-icon.spinning {
    transform: rotate(360deg);
  }
</style>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const html = document.documentElement
    const isDark = html.classList.contains('dark')
    const icons = document.querySelectorAll('.theme-icon')

    // Spin animation
    icons.forEach(icon => {
      icon.classList.add('spinning')
      setTimeout(() => icon.classList.remove('spinning'), 400)
    })

    if (isDark) {
      html.classList.remove('dark')
      localStorage.setItem('belajar-cpp-theme', 'light')
    } else {
      html.classList.add('dark')
      localStorage.setItem('belajar-cpp-theme', 'dark')
    }
  })
</script>
