---
import type { Language } from '@/types/lesson'

interface Props {
  lang: Language
  currentPath: string
}
const { lang, currentPath } = Astro.props

// Build the switched path: /id/... -> /en/... and vice versa
const otherLang = lang === 'id' ? 'en' : 'id'
const switchedPath = currentPath.replace(new RegExp(`^/${lang}(/|$)`), `/${otherLang}$1`)
---
<a
  href={switchedPath || `/${otherLang}`}
  class="flex items-center gap-0.5 px-2 py-1.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
  aria-label={`Switch to ${otherLang === 'id' ? 'Indonesian' : 'English'}`}
  data-lang-toggle
>
  <span class:list={[lang === 'id' ? 'font-bold text-slate-900 dark:text-slate-100' : 'text-slate-400 dark:text-slate-500']}>ID</span>
  <span class="text-slate-300 dark:text-slate-600">|</span>
  <span class:list={[lang === 'en' ? 'font-bold text-slate-900 dark:text-slate-100' : 'text-slate-400 dark:text-slate-500']}>EN</span>
</a>

<script is:inline>
  // Save language preference
  document.querySelector('[data-lang-toggle]')?.addEventListener('click', () => {
    const href = document.querySelector('[data-lang-toggle]')?.getAttribute('href') || ''
    const newLang = href.startsWith('/en') ? 'en' : 'id'
    localStorage.setItem('belajar-cpp-lang', newLang)
  })
</script>
