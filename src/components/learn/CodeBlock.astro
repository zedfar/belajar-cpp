---
import { Code } from 'astro:components'

interface Props {
  code: string
  lang?: string
  filename?: string
  showLineNumbers?: boolean
  highlightLines?: number[]
  caption?: string
}
const { code, lang = 'cpp', filename, showLineNumbers = true, caption } = Astro.props

const langLabels: Record<string, string> = {
  cpp: 'C++',
  c: 'C',
  js: 'JavaScript',
  javascript: 'JavaScript',
  ts: 'TypeScript',
  typescript: 'TypeScript',
  bash: 'Bash',
  sh: 'Shell',
  json: 'JSON',
  html: 'HTML',
  css: 'CSS',
  text: 'Output',
}
const langLabel = langLabels[lang] ?? lang.toUpperCase()
---

<div class="my-5 rounded-xl overflow-hidden border border-slate-700/60 bg-[#1e1e2e] shadow-lg shadow-black/20">
  <!-- Top bar -->
  <div class="flex items-center justify-between px-4 py-2.5 bg-[#181825] border-b border-slate-700/50">
    <div class="flex items-center gap-2">
      {filename ? (
        <>
          <!-- Traffic lights + filename -->
          <div class="flex items-center gap-1.5 mr-2">
            <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
            <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
            <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          <span class="text-xs text-slate-400 font-mono">{filename}</span>
        </>
      ) : (
        <!-- Traffic lights only -->
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
        </div>
      )}
    </div>

    <!-- Right: language badge + copy button -->
    <div class="flex items-center gap-2">
      <span class="text-[10px] font-mono font-semibold px-2 py-0.5 rounded bg-slate-700/60 text-slate-400 uppercase tracking-wide">
        {langLabel}
      </span>
      <button
        class="copy-btn flex items-center gap-1.5 px-2 py-1 rounded-md text-xs text-slate-400 hover:text-slate-200 hover:bg-slate-700/60 transition-all duration-150"
        data-code={code.trim()}
        aria-label="Copy code"
      >
        <!-- Clipboard icon (default) -->
        <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <!-- Check icon (shown after copy) -->
        <svg class="check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <span class="copy-label">Copy</span>
      </button>
    </div>
  </div>

  <!-- Code area -->
  <div class:list={['overflow-x-auto text-sm', showLineNumbers && 'code-with-line-numbers']}>
    <Code code={code.trim()} lang={lang as any} theme="one-dark-pro" />
  </div>

  {caption && (
    <div class="px-4 py-2 bg-[#181825] border-t border-slate-700/50 text-xs text-slate-500 italic">
      {caption}
    </div>
  )}
</div>

<style>
  .code-with-line-numbers :global(pre) {
    counter-reset: line;
  }
  .code-with-line-numbers :global(pre .line) {
    position: relative;
    padding-left: 3.5em;
  }
  .code-with-line-numbers :global(pre .line::before) {
    counter-increment: line;
    content: counter(line);
    position: absolute;
    left: 0;
    width: 2.5em;
    text-align: right;
    color: #4a5568;
    user-select: none;
    border-right: 1px solid #2d3748;
    padding-right: 0.75em;
    margin-right: 0.75em;
  }
  :global(.astro-code) {
    padding: 1rem 1.25rem;
    margin: 0;
    background: transparent !important;
    line-height: 1.7;
  }
  /* Thin scrollbar */
  .overflow-x-auto::-webkit-scrollbar { height: 5px; }
  .overflow-x-auto::-webkit-scrollbar-track { background: transparent; }
  .overflow-x-auto::-webkit-scrollbar-thumb { background: #374151; border-radius: 9999px; }
  .overflow-x-auto::-webkit-scrollbar-thumb:hover { background: #4b5563; }
</style>

<script is:inline>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code') || ''
      const copyIcon = btn.querySelector('.copy-icon')
      const checkIcon = btn.querySelector('.check-icon')
      const label = btn.querySelector('.copy-label')

      try {
        await navigator.clipboard.writeText(code)
      } catch {
        const ta = document.createElement('textarea')
        ta.value = code
        ta.style.position = 'fixed'
        ta.style.opacity = '0'
        document.body.appendChild(ta)
        ta.select()
        document.execCommand('copy')
        document.body.removeChild(ta)
      }

      // Show checkmark
      copyIcon?.classList.add('hidden')
      checkIcon?.classList.remove('hidden')
      if (label) label.textContent = 'Copied!'
      btn.classList.add('text-emerald-400', 'bg-emerald-900/30')

      setTimeout(() => {
        copyIcon?.classList.remove('hidden')
        checkIcon?.classList.add('hidden')
        if (label) label.textContent = 'Copy'
        btn.classList.remove('text-emerald-400', 'bg-emerald-900/30')
      }, 2000)
    })
  })
</script>
