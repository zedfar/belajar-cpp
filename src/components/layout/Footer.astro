---
import { t } from '@/lib/i18n'
import type { Language } from '@/types/lesson'

interface Props {
  lang: Language
}
const { lang } = Astro.props
---
<footer class="border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
      <p>{t(lang, 'footer.madeWith')}</p>
      <div class="flex items-center gap-4">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-slate-700 dark:hover:text-slate-200 transition-colors"
        >
          {t(lang, 'footer.openSource')}
        </a>
        <span class="text-slate-300 dark:text-slate-700">|</span>
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-slate-700 dark:hover:text-slate-200 transition-colors"
        >
          {t(lang, 'footer.reportIssue')}
        </a>
      </div>
      <p class="text-xs text-slate-400 dark:text-slate-500">
        &copy; {new Date().getFullYear()} Belajar C++ &middot; v0.1.0
      </p>
    </div>
  </div>
</footer>
