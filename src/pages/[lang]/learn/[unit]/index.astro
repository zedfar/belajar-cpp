---
import PageLayout from '@/layouts/PageLayout.astro'
import { t, interpolate } from '@/lib/i18n'
import { CURRICULUM_ID, getLessonUrl } from '@/lib/curriculum'
import type { Language } from '@/types/lesson'

export function getStaticPaths() {
  const paths: { params: { lang: string; unit: string } }[] = []
  const langs: Language[] = ['id', 'en']
  for (const lang of langs) {
    for (const unit of CURRICULUM_ID) {
      paths.push({ params: { lang, unit: unit.slug } })
    }
  }
  return paths
}

const { lang, unit: unitSlug } = Astro.params as { lang: Language; unit: string }
const unit = CURRICULUM_ID.find(u => u.slug === unitSlug)

if (!unit) {
  return Astro.redirect(`/${lang}/curriculum`)
}

const firstLesson = unit.lessons[0]
const firstLessonUrl = getLessonUrl(lang, firstLesson.slug)
const totalTime = unit.lessons.reduce((sum, l) => sum + l.estimatedTime, 0)
---
<PageLayout title={`Unit ${unit.id}: ${unit.title[lang]}`} description={unit.description[lang]} lang={lang}>
  <div class="max-w-3xl mx-auto">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-slate-500 dark:text-slate-400">
      <a href={`/${lang}/curriculum`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
        {t(lang, 'nav.curriculum')}
      </a>
      <span class="mx-2">/</span>
      <span class="text-slate-700 dark:text-slate-300">Unit {unit.id}</span>
    </nav>

    <!-- Unit Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-xs font-mono px-2 py-1 rounded bg-primary-100 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300 font-semibold">
          Unit {unit.id}
        </span>
        {!unit.isAvailable && (
          <span class="text-xs px-2 py-0.5 rounded bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300">
            {t(lang, 'curriculum.comingSoon')}
          </span>
        )}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-3">
        {unit.title[lang]}
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-4">
        {unit.description[lang]}
      </p>
      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          ~{unit.estimatedHours} {lang === 'id' ? 'jam' : 'hours'}
        </span>
        <span>{unit.lessons.length} {lang === 'id' ? 'pelajaran' : 'lessons'}</span>
        <span>~{totalTime} {lang === 'id' ? 'menit total' : 'minutes total'}</span>
      </div>
    </div>

    <!-- Unit Progress -->
    <div class="mb-8 p-4 rounded-lg bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-slate-700 dark:text-slate-300">
          {lang === 'id' ? 'Progress Unit' : 'Unit Progress'}
        </span>
        <span class="text-sm text-slate-500 dark:text-slate-400" id="unit-progress-text">
          0 / {unit.lessons.length}
        </span>
      </div>
      <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
        <div id="unit-progress-bar" class="h-full bg-emerald-500 rounded-full transition-all duration-500" style="width: 0%"></div>
      </div>
    </div>

    <!-- Lessons List -->
    <div class="space-y-2 mb-10">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">
        {lang === 'id' ? 'Daftar Pelajaran' : 'Lesson List'}
      </h2>
      {unit.lessons.map((lesson, idx) => {
        const lessonUrl = getLessonUrl(lang, lesson.slug)
        return (
          <a
            href={unit.isAvailable ? lessonUrl : undefined}
            class:list={[
              'flex items-center gap-4 p-4 rounded-lg border transition-all',
              unit.isAvailable
                ? 'border-slate-200 dark:border-slate-800 hover:border-primary-300 dark:hover:border-primary-700 hover:bg-primary-50/50 dark:hover:bg-primary-950/20 cursor-pointer'
                : 'border-slate-200 dark:border-slate-800 opacity-50 cursor-not-allowed'
            ]}
            data-lesson-link={lesson.slug}
          >
            <!-- Status circle -->
            <div class="flex-shrink-0 w-8 h-8 rounded-full border-2 border-slate-300 dark:border-slate-600 flex items-center justify-center" data-lesson-circle={lesson.slug}>
              <span class="text-xs font-mono text-slate-400 dark:text-slate-500">{idx + 1}</span>
            </div>

            <!-- Lesson info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-slate-900 dark:text-white truncate">
                  {lesson.title[lang]}
                </span>
                {lesson.isProject && (
                  <span class="text-[10px] px-1.5 py-0.5 rounded bg-accent-100 dark:bg-accent-900/40 text-accent-700 dark:text-accent-300 font-medium flex-shrink-0">
                    Project
                  </span>
                )}
              </div>
              <span class="text-xs text-slate-500 dark:text-slate-400">
                {interpolate(t(lang, 'lesson.estimatedTime'), { time: String(lesson.estimatedTime) })}
              </span>
            </div>

            <!-- Arrow -->
            {unit.isAvailable && (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-slate-300 dark:text-slate-600">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            )}
          </a>
        )
      })}
    </div>

    <!-- Project info -->
    <div class="p-6 rounded-xl bg-gradient-to-r from-primary-50 to-accent-50 dark:from-primary-950/30 dark:to-accent-950/30 border border-primary-200 dark:border-primary-800 mb-10">
      <div class="flex items-center gap-2 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600 dark:text-primary-400">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        <h3 class="font-semibold text-primary-900 dark:text-primary-100">
          {t(lang, 'curriculum.project')}
        </h3>
      </div>
      <p class="text-sm text-primary-800 dark:text-primary-200">
        {unit.projectTitle[lang]}
      </p>
    </div>

    <!-- Start/Continue button -->
    {unit.isAvailable && (
      <div class="text-center">
        <a
          href={firstLessonUrl}
          id="start-continue-btn"
          class="inline-flex items-center gap-2 px-8 py-3 rounded-lg bg-primary-600 hover:bg-primary-700 text-white font-semibold text-lg transition-colors shadow-lg shadow-primary-600/25"
        >
          {t(lang, 'progress.startLearning')}
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </a>
      </div>
    )}
  </div>

  <script is:inline define:vars={{ unitSlug, lessonCount: unit.lessons.length, lang }}>
    try {
      const raw = localStorage.getItem('belajar-cpp-progress')
      if (raw) {
        const progress = JSON.parse(raw)
        const completed = (progress.completedLessons || []).filter(s => s.startsWith(unitSlug + '/'))

        // Update progress bar
        const pct = Math.round((completed.length / lessonCount) * 100)
        const bar = document.getElementById('unit-progress-bar')
        const text = document.getElementById('unit-progress-text')
        if (bar) bar.style.width = pct + '%'
        if (text) text.textContent = `${completed.length} / ${lessonCount}`

        // Update lesson circles
        completed.forEach(slug => {
          const circle = document.querySelector(`[data-lesson-circle="${slug}"]`)
          if (circle) {
            circle.classList.remove('border-slate-300', 'dark:border-slate-600')
            circle.classList.add('border-emerald-500', 'bg-emerald-500')
            circle.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>'
          }
        })

        // Update start/continue button
        if (completed.length > 0 && completed.length < lessonCount) {
          const btn = document.getElementById('start-continue-btn')
          if (btn) {
            btn.textContent = lang === 'id' ? 'Lanjutkan Belajar' : 'Continue Learning'
          }
        }
      }
    } catch {}
  </script>
</PageLayout>
