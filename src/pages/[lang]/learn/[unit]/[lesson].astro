---
import { getCollection, render as renderEntry } from 'astro:content'
import LessonLayout from '@/layouts/LessonLayout.astro'
import CodeBlock from '@/components/learn/CodeBlock.astro'
import InfoBox from '@/components/learn/InfoBox.astro'
import LessonNav from '@/components/learn/LessonNav.astro'
import TableOfContents from '@/components/common/TableOfContents.astro'
import { CURRICULUM_ID, getLessonUrl } from '@/lib/curriculum'
import { t, interpolate } from '@/lib/i18n'
import type { Language } from '@/types/lesson'

export async function getStaticPaths() {
  const lessonsId = await getCollection('lessons-id')
  const lessonsEn = await getCollection('lessons-en')

  const paths: {
    params: { lang: string; unit: string; lesson: string }
    props: { entry: any; collectionName: string }
  }[] = []

  for (const entry of lessonsId) {
    // entry.id is like "unit-0/01-apa-itu-programming" (Astro v5: .id replaces .slug)
    const id = entry.id ?? (entry as any).slug
    const parts = id.split('/')
    if (parts.length !== 2) continue
    paths.push({
      params: { lang: 'id', unit: parts[0], lesson: parts[1] },
      props: { entry, collectionName: 'lessons-id' },
    })
  }

  for (const entry of lessonsEn) {
    const id = entry.id ?? (entry as any).slug
    const parts = id.split('/')
    if (parts.length !== 2) continue
    paths.push({
      params: { lang: 'en', unit: parts[0], lesson: parts[1] },
      props: { entry, collectionName: 'lessons-en' },
    })
  }

  return paths
}

const { lang, unit: unitSlug, lesson: lessonSlug } = Astro.params as {
  lang: Language
  unit: string
  lesson: string
}
const { entry } = Astro.props

const fullSlug = `${unitSlug}/${lessonSlug}`
// Astro v5 uses render(entry) from astro:content
const { Content, headings } = await renderEntry(entry)

// Find unit metadata
const unit = CURRICULUM_ID.find(u => u.slug === unitSlug)
const lessonMeta = unit?.lessons.find(l => l.slug === fullSlug)

// Difficulty badge color
const difficultyColor = entry.data.difficulty === 'intermediate'
  ? 'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300'
  : 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300'
---
<LessonLayout
  title={entry.data.title}
  description={entry.data.description}
  lang={lang}
  currentLessonSlug={fullSlug}
  unitSlug={unitSlug}
>
  <!-- Lesson Header -->
  <div class="mb-8">
    <!-- Breadcrumb -->
    <nav class="mb-4 text-sm text-slate-500 dark:text-slate-400">
      <a href={`/${lang}/curriculum`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
        {t(lang, 'nav.curriculum')}
      </a>
      <span class="mx-1.5">/</span>
      <a href={`/${lang}/learn/${unitSlug}`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
        {unit?.title[lang] || unitSlug}
      </a>
      <span class="mx-1.5">/</span>
      <span class="text-slate-700 dark:text-slate-300">{entry.data.title}</span>
    </nav>

    <h1 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-3">
      {entry.data.title}
    </h1>

    <!-- Meta row -->
    <div class="flex flex-wrap items-center gap-3 text-sm mb-4">
      <span class="flex items-center gap-1 text-slate-500 dark:text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        {interpolate(t(lang, 'lesson.estimatedTime'), { time: String(entry.data.estimatedTime) })}
      </span>
      <span class={`text-xs px-2 py-0.5 rounded font-medium ${difficultyColor}`}>
        {entry.data.difficulty === 'intermediate'
          ? (lang === 'id' ? 'Menengah' : 'Intermediate')
          : (lang === 'id' ? 'Pemula' : 'Beginner')}
      </span>
      {lessonMeta?.isProject && (
        <span class="text-xs px-2 py-0.5 rounded bg-accent-100 dark:bg-accent-900/40 text-accent-700 dark:text-accent-300 font-medium">
          Project
        </span>
      )}
    </div>

    <!-- Objectives -->
    {entry.data.objectives && entry.data.objectives.length > 0 && (
      <div class="p-4 rounded-lg bg-primary-50 dark:bg-primary-950/30 border border-primary-200 dark:border-primary-800">
        <h2 class="text-sm font-semibold text-primary-900 dark:text-primary-100 mb-2">
          {t(lang, 'lesson.objectives')}
        </h2>
        <ul class="space-y-1">
          {entry.data.objectives.map((obj: string) => (
            <li class="flex items-start gap-2 text-sm text-primary-800 dark:text-primary-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5">
                <polyline points="9 11 12 14 22 4"/>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
              </svg>
              {obj}
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>

  <!-- Table of Contents -->
  <TableOfContents headings={headings} lang={lang} />

  <!-- Lesson Content (MDX rendered) -->
  <article class="prose prose-slate dark:prose-invert max-w-none
    prose-headings:scroll-mt-20
    prose-h2:text-xl prose-h2:font-bold prose-h2:mt-10 prose-h2:mb-4
    prose-h3:text-lg prose-h3:font-semibold prose-h3:mt-8 prose-h3:mb-3
    prose-p:leading-relaxed prose-p:text-slate-700 prose-p:dark:text-slate-300
    prose-li:text-slate-700 prose-li:dark:text-slate-300
    prose-strong:text-slate-900 prose-strong:dark:text-white
    prose-code:text-primary-600 prose-code:dark:text-primary-400 prose-code:bg-primary-50 prose-code:dark:bg-primary-950/30 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
    prose-pre:p-0 prose-pre:bg-transparent prose-pre:border-0
    prose-a:text-primary-600 prose-a:dark:text-primary-400 prose-a:underline-offset-2
    prose-blockquote:border-primary-300 prose-blockquote:dark:border-primary-700
  ">
    <Content />
  </article>

  <!-- Mark complete button -->
  <div class="mt-10 flex justify-center">
    <button
      id="mark-complete-btn"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border-2 border-emerald-500 text-emerald-600 dark:text-emerald-400 font-medium hover:bg-emerald-50 dark:hover:bg-emerald-950/30 transition-colors"
      data-lesson-slug={fullSlug}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      <span>{t(lang, 'lesson.markComplete')}</span>
    </button>
  </div>

  <!-- Lesson Navigation -->
  <LessonNav currentSlug={fullSlug} lang={lang} />
</LessonLayout>

<script is:inline>
  // Mark complete button
  const btn = document.getElementById('mark-complete-btn')
  if (btn) {
    const slug = btn.getAttribute('data-lesson-slug')

    // Check if already completed
    try {
      const raw = localStorage.getItem('belajar-cpp-progress')
      if (raw) {
        const progress = JSON.parse(raw)
        if (progress.completedLessons?.includes(slug)) {
          btn.classList.remove('border-emerald-500', 'text-emerald-600', 'dark:text-emerald-400', 'hover:bg-emerald-50', 'dark:hover:bg-emerald-950/30')
          btn.classList.add('bg-emerald-500', 'text-white', 'border-emerald-500')
          btn.querySelector('span').textContent = '\u2713 Selesai'
          btn.disabled = true
        }
      }
    } catch {}

    btn.addEventListener('click', () => {
      try {
        let raw = localStorage.getItem('belajar-cpp-progress')
        let progress = raw ? JSON.parse(raw) : {
          completedLessons: [],
          currentLesson: null,
          exerciseResults: {},
          quizResults: {},
          language: 'id',
          theme: 'light',
          lastVisited: new Date().toISOString(),
          streakDays: 0,
          lastActiveDate: new Date().toISOString().split('T')[0],
          unlockedBadges: [],
        }

        if (!progress.completedLessons.includes(slug)) {
          progress.completedLessons.push(slug)
        }
        progress.currentLesson = slug
        progress.lastVisited = new Date().toISOString()

        localStorage.setItem('belajar-cpp-progress', JSON.stringify(progress))

        // Update button appearance
        btn.classList.remove('border-emerald-500', 'text-emerald-600', 'dark:text-emerald-400', 'hover:bg-emerald-50', 'dark:hover:bg-emerald-950/30')
        btn.classList.add('bg-emerald-500', 'text-white', 'border-emerald-500')
        btn.querySelector('span').textContent = '\u2713 Selesai'
        btn.disabled = true
      } catch {}
    })
  }
</script>
