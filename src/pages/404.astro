---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'

// Detect language from URL
const path = Astro.url.pathname
const lang = path.startsWith('/en') ? 'en' : 'id'
---
<BaseLayout title={lang === 'id' ? 'Halaman Tidak Ditemukan' : 'Page Not Found'} lang={lang}>
  <div class="flex flex-col min-h-screen">
    <Header lang={lang} currentPath={path} />

    <main class="flex-1 flex items-center justify-center px-4">
      <div class="text-center max-w-md">
        <!-- Big 404 -->
        <div class="text-8xl font-bold text-slate-200 dark:text-slate-800 mb-4 font-mono">404</div>

        <!-- Fun message -->
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">
          {lang === 'id' ? 'Oops! Halaman tidak ditemukan' : 'Oops! Page not found'}
        </h1>
        <p class="text-slate-600 dark:text-slate-400 mb-2">
          {lang === 'id'
            ? 'Sepertinya kamu tersesat di dunia kode... Segmentation fault!'
            : 'Looks like you got lost in code... Segmentation fault!'}
        </p>
        <p class="text-sm text-slate-500 dark:text-slate-500 mb-8 font-mono">
          {`error: '${path}' was not declared in this scope`}
        </p>

        <!-- Links -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href={`/${lang}`}
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-primary-600 hover:bg-primary-700 text-white font-medium transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            {lang === 'id' ? 'Kembali ke Beranda' : 'Back to Home'}
          </a>
          <a
            href={`/${lang}/curriculum`}
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border border-slate-300 dark:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 font-medium transition-colors"
          >
            {lang === 'id' ? 'Lihat Kurikulum' : 'View Curriculum'}
          </a>
        </div>
      </div>
    </main>

    <Footer lang={lang} />
  </div>
</BaseLayout>
